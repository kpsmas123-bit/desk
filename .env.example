# The web address of your Supabase project (the database that stores your data)
SUPABASE_URL=
# The public key Supabase gives you — safe to use in the website
SUPABASE_PUBLISHABLE_KEY=
# The secret Supabase key — keep this private, used by background scripts only
SUPABASE_SECRET_KEY=
# Your Open States API key — lets the scripts download legislative data
OPENSTATES_API_KEY=
# Your Anthropic (Claude) API key — lets the scripts use AI features
ANTHROPIC_API_KEY=
